{
  "family": "sitaware-web",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/sitaware-ecs-execution-role",
  "taskRoleArn": "arn:aws:iam::ACCOUNT_ID:role/sitaware-web-task-role",
  "containerDefinitions": [
    {
      "name": "web",
      "image": "ACCOUNT_ID.dkr.ecr.REGION.amazonaws.com/sitaware/web:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3000,
          "protocol": "tcp"
        }
      ],
      "healthCheck": {
        "command": ["CMD", "node", "healthcheck.js"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 30
      },
      "environment": [
        { "name": "NEXT_PUBLIC_API_URL", "value": "https://sitaware.example.com" },
        { "name": "WS_URL", "value": "wss://sitaware.example.com" },
        { "name": "API_INTERNAL_URL", "value": "http://api.sitaware.local:8080" },
        { "name": "HOSTNAME", "value": "0.0.0.0" },
        { "name": "PORT", "value": "3000" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/sitaware-web",
          "awslogs-region": "REGION",
          "awslogs-stream-prefix": "web"
        }
      }
    }
  ]
}
