# =============================================================================
# SitAware Configuration
# Copy this file to .env and update values for your environment
# =============================================================================

# --- Admin Bootstrap ---
# Created on first startup if no admin user exists
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
ADMIN_EMAIL=admin@sitaware.local

# --- API Server ---
API_HOST=0.0.0.0
API_PORT=8080
API_LOG_LEVEL=debug

# --- JWT ---
JWT_SECRET=change-this-to-a-random-secret-in-production
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=168h

# --- Database (PostgreSQL + PostGIS) ---
DB_HOST=postgres
DB_PORT=5432
DB_USER=sitaware
DB_PASSWORD=sitaware
DB_NAME=sitaware
DB_SSLMODE=disable

# --- Redis (Pub/Sub) ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
# Enable TLS for Redis connections (required for ElastiCache with transit encryption)
REDIS_TLS=false
# Enable Redis Cluster mode (required for ElastiCache with cluster mode enabled)
REDIS_CLUSTER=false

# --- Object Storage (S3 / Minio) ---
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=sitaware
S3_SECRET_KEY=sitaware123
S3_BUCKET=sitaware
S3_REGION=us-east-1
S3_USE_PATH_STYLE=true

# --- WebSocket ---
WS_LOCATION_THROTTLE=1s

# --- Web Client ---
# WebSocket URL for browser connections (must be reachable from browser)
# Not prefixed with NEXT_PUBLIC_ so it is read at runtime by the server,
# then passed to the client via props (NEXT_PUBLIC_ vars are inlined at build time).
WS_URL=ws://localhost:8080

# --- CORS ---
# Comma-separated list of allowed origins. Use * for development.
CORS_ALLOWED_ORIGINS=*

# --- Rate Limiting ---
RATE_LIMIT_RPS=10
RATE_LIMIT_BURST=20

# --- Security ---
# Maximum request body size in bytes (default 10MB)
MAX_REQUEST_BODY_BYTES=10485760

# --- Token Cleanup ---
# How often to purge expired refresh tokens
TOKEN_CLEANUP_INTERVAL=1h

# --- MFA / WebAuthn ---
# WebAuthn Relying Party ID (your domain, no port). Defaults to localhost for dev.
WEBAUTHN_RP_ID=localhost
# Display name shown in browser credential prompts
WEBAUTHN_RP_DISPLAY_NAME=SitAware
# Comma-separated list of allowed WebAuthn origins (must match browser origin exactly)
WEBAUTHN_RP_ORIGINS=http://localhost:3000
# Optional: AWS KMS key ARN for encrypting TOTP secrets at rest.
# When empty, TOTP secrets are encrypted with AES-256-GCM derived from JWT_SECRET via HKDF.
# MFA_KMS_KEY_ARN=arn:aws:kms:us-east-1:123456789012:key/your-key-id

# --- Map Defaults ---
MAP_DEFAULT_TILE_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png
MAP_DEFAULT_CENTER_LAT=0
MAP_DEFAULT_CENTER_LNG=0
MAP_DEFAULT_ZOOM=2
MAP_DEFAULT_TERRAIN_URL=https://s3.amazonaws.com/elevation-tiles-prod/terrarium/{z}/{x}/{y}.png
